<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="409dp"
        android:layout_height="354dp"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_gravity="center"
            android:text="          Food Order App"
            android:textAlignment="textStart"
            android:textColor="#2196F3"
            android:textSize="34sp"
            android:textStyle="bold"
            android:padding="15dp"/>

        <TextView
            android:id="@+id/mealType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Meal Type"
            android:textColor="#E91E63"
            android:textStyle="bold" />
        <RadioGroup
            android:id="@+id/radioGroup"
            android:layout_width="match_parent"
            android:layout_height="match_parent" >

            <RadioButton
                android:id="@+id/radioVeg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Veg" />

            <RadioButton
                android:id="@+id/radioNonVeg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NonVeg" />
        </RadioGroup>

        <CheckBox
            android:id="@+id/checkCheese"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Extra Cheese" />

        <CheckBox
            android:id="@+id/checkDrink"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Cold Drink" />

        <ToggleButton
            android:id="@+id/toggleButton"
            android:layout_width="163dp"
            android:layout_height="wrap_content"
            android:textColor="#161515"
            android:textOff="Take Away"
            android:textOn="Home Delivery" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rate Us"
            android:textStyle="bold"/>

        <RatingBar
            android:id="@+id/ratingBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:progressTint="#1EE925" />

        <Spinner
            android:id="@+id/spinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/btnOrder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Place Order"/>

    </LinearLayout>

</ScrollView>